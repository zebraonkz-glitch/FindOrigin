# Telegram Bot API
TELEGRAM_BOT_TOKEN=
# Опционально: секрет для заголовка X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=

# OpenAI API (или совместимый провайдер, по умолчанию OpenRouter)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
# Для прямого OpenAI API: OPENAI_BASE_URL=https://api.openai.com/v1 и OPENAI_MODEL=gpt-4o-mini

# Serper Search API — https://serper.dev
SEARCH_API_KEY=
